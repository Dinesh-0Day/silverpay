# Copy values into Railway service variables (not all on one service).

# === backend service ===
NODE_ENV=production
JWT_SECRET=change-me-minimum-32-characters-long
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/silverpay
CORS_ORIGINS=https://your-app.up.railway.app,https://your-admin.up.railway.app
ALLOW_ENV_ADMIN_BOOTSTRAP=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

# === app service (build variable) ===
VITE_API_BASE_URL=https://your-api.up.railway.app

# === admin service (build variable) ===
VITE_API_BASE_URL=https://your-api.up.railway.app
