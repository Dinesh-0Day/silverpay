MONGODB_URI="mongodb://127.0.0.1:27017/silverpay"
# Local standalone MongoDB cannot use transactions — auto-fallback is built-in, or set:
# MONGODB_DISABLE_TRANSACTIONS=true
JWT_SECRET="use-a-long-random-string-at-least-32-characters"
PORT=4000

# Admin is created ONLY via: npm run db:seed (never via public API)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME=""

# Optional: server-side only, disabled by default
# ALLOW_ENV_ADMIN_BOOTSTRAP=true

# Production: comma-separated origins
# CORS_ORIGINS="https://admin.yourdomain.com,https://app.yourdomain.com"

# Paytm auto UPI (order/status API polling)
# PAYTM_ENV="production"
# PAYMENT_TIMEOUT_SECONDS=300
# PAYMENT_CHECK_INTERVAL_MS=10000

# Crypto: defaults until set in admin Settings → Home rates
# USDT_TO_INR_RATE=83
# MIN_USDT_DEPOSIT=1

# Mobile OTP: configure apihome.in API key in Admin → Settings → SMS OTP (never put SMS key in .env)
# Dev only: OTP printed in server console when SMS disabled; OTP_DEV_EXPOSE=true shows OTP in signup API response
# OTP_DEV_EXPOSE=true
